# ─── Supabase (auth + file uploads) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Server-side key for the cron job's Supabase writes (never expose to client)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── AI providers ───────────────────────────────────────────────
# OpenAI (content generation workers, image generation, transcription, web search)
OPENAI_API_KEY="sk-..."
# Anthropic Claude (CEO/premium agent, Blanc Mode, Copy Copilot)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Research & scraping ────────────────────────────────────────
# Apify (social profile/post scraping for Competitor Intel)
APIFY_API_TOKEN="apify_api_..."
# Shared secret embedded in the Apify webhook URL (any long random string)
APIFY_WEBHOOK_SECRET="generate-a-long-random-string"
# Exa (deep research web search)
EXA_API_KEY="..."
# Tavily (fallback web search for the algo-scout cron)
TAVILY_API_KEY="tvly-..."
# RapidAPI (Instagram data fallback)
RAPIDAPI_INSTAGRAM_KEY="..."

# ─── Google Cloud / BigQuery (Competitor Intel storage) ─────────
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
# BigQuery auth uses Application Default Credentials:
# run `gcloud auth application-default login` locally, or set
# GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path.

# ─── App / infrastructure ───────────────────────────────────────
# Stable public URL of the deployed app (used for Apify webhook callbacks).
# Set this on Vercel to your production domain.
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
# Secret protecting /api/cron/algo-scout (Vercel Cron sends it automatically
# once set in the Vercel env; any long random string)
CRON_SECRET="generate-a-long-random-string"
